<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/black">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/add_task_title"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="40dp"
        android:gravity="center" />

    <!-- Task Name Input Field -->
    <EditText
        android:id="@+id/et_task_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/et_task_name_hint"
        android:textColor="@color/white"
        android:textColorHint="#666666"
        android:background="@drawable/field_bg"
        android:padding="16dp"
        android:layout_marginBottom="20dp"
        android:gravity="center" />

    <!-- Category Selector (Replaces Spinner) -->
    <TextView
        android:id="@+id/tv_task_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Category"
        android:textColor="@color/white"
        android:background="@drawable/field_bg"
        android:padding="16dp"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

    <!-- Time Picker Field -->
    <TextView
        android:id="@+id/tv_pick_time_display"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Notification Time"
        android:textColor="@color/white"
        android:background="@drawable/field_bg"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true" />

    <TextView
        android:id="@+id/tv_selected_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_time_selected"
        android:textColor="#BBBBBB"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"
        android:gravity="center" />

    <Button
        android:id="@+id/btn_save_task"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_save_task"
        android:backgroundTint="@color/white"
        android:textColor="@color/black"
        android:padding="14dp"
        android:textStyle="bold" />

</LinearLayout>
