<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Petcare" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColorPrimary">@color/white</item>

        <!-- To remove the splash icon on Android 12+ (API 31+) -->
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@android:color/transparent</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/black</item>
    </style>

    <style name="Theme.Petcare" parent="Base.Theme.Petcare" />
</resources>
